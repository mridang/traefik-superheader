{
  "$schema": "https://raw.githubusercontent.com/jetpack-io/devbox/0.10.3/.schema/devbox.schema.json",
  "packages": [
    "golangci-lint@latest",
    "go@1.22",
    "tinygo@0.33.0",
    "gotestsum@latest"
  ],
  "shell": {
    "scripts": {
      "test": "make test",
      "build": "make build",
      "lint": "make lint",
      "format": "make format"
    }
  },
  "env": {
    "GOMODCACHE": "$DEVBOX_PROJECT_ROOT/.go",
    "GOTOOLCHAIN": "local",
    "GOROOT": null
  }
}
